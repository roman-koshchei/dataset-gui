{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-set-title",
    "fs:allow-open",
    "fs:allow-write-text-file",
    "fs:allow-write",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file-lines",
    "fs:allow-remove",
    "opener:allow-reveal-item-in-dir",
    {
      "identifier": "fs:scope",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "fs:default",
    "store:default"
  ]
}